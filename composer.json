{
    "name": "jcergolj/rector-for-laravel",
    "description": "Rector rules for Laravel projects",
    "require": {
        "driftingly/rector-laravel": "2.*"
    },
    "scripts": {
        "pint": "vendor/bin/pint",
        "phpunit": "vendor/bin/phpunit",
        "analyse": [
            "@pint",
            "@phpunit"
        ]
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "phpunit/phpunit": "^13.0"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Jcergolj\\RectorForLaravel\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Janez Cergolj"
        }
    ],
    "minimum-stability": "dev",
    "extra": {
        "laravel": {
            "providers": [
                "Jcergolj\\RectorForLaravel\\RectorForLaravelServiceProvider"
            ]
        }
    }
}
